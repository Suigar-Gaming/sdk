{
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": false,
		"outDir": "dist",
		"strict": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"lib": ["ES2022"]
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts", "vitest.config.ts"]
}
